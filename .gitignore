# Ignore the executable files
*.exe
*.dll
*.so
*.dylib
*.test

# Ignore the build output directory if you use one
/bin/
/build/

# Ignore vendor directory if dependencies are vendored
vendor/

# Ignore editor and IDE files
.idea/
.vscode/

# Ignore temporary files
*.tmp
*.bak

# Ignore log files
*.log

# Ignore coverage reports
coverage.out

# Ignore environment variable files
.env
.env.* 

# Ignore Go cache and build artifacts
/$(GOPATH)/pkg/mod
/.cache/